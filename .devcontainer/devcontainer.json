{
  "name": "AI Agent Infrastructure",
  "build": { "dockerfile": "Dockerfile" },
  "customizations": {
    "vscode": { "extensions": ["anthropic.claude-code"] }
  },
  "remoteUser": "node",
  // To use host windows ssh agent, set forwardAgent to true and ensure you have an ssh agent running on your host machine with the appropriate keys added.
  "forwardAgent": true,
  // "postCreateCommand": "npm install -g @anthropic-ai/claude-code",
  "postCreateCommand": "npm install -g @anthropic-ai/claude-code && echo 'alias claude=\"claude --model qwen3-coder:30b --dangerously-skip-permissions\"' >> ~/.bashrc",
  "containerEnv": {
    "ANTHROPIC_BASE_URL": "http://host.docker.internal:11434/v1",
    "ANTHROPIC_AUTH_TOKEN": "ollama",
    "ANTHROPIC_API_KEY": "ollama",
    "CLAUDE_MODEL": "qwen3-coder:30b"
  }
}